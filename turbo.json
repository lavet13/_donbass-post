{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "src/**/*.tsx",
        "*.config.js"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "preview": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build", "check-types", "^db:generate"],
      "outputs": ["dist/**"],
      "env": ["VITE_*", "NODE_ENV"]
    },
    "dev": {
      "with": ["db:studio"],
      "dependsOn": ["db:generate"],
      "cache": false,
      "persistent": true,
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:reset": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true,
    },
    "db:deploy": {
      "cache": false
    }
  }
}
